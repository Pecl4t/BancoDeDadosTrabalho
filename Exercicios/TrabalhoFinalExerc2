-- QUESTÃO B:
CREATE TABLE PESSOA (
    CPF VARCHAR(11) NOT NULL,
    Nome VARCHAR(50) NOT NULL,
    Sexo CHAR(1) NOT NULL,
    CONSTRAINT PK_PESSOA PRIMARY KEY (CPF)
);

CREATE TABLE ENDERECO (
    id_endereco SERIAL, 
    Cidade VARCHAR(50) NOT NULL,
    Estado CHAR(2) NOT NULL,
    CPF_pessoa VARCHAR(11) NOT NULL,
    CONSTRAINT PK_ENDERECO PRIMARY KEY (id_endereco),
    CONSTRAINT FK_ENDERECO_PESSOA FOREIGN KEY (CPF_pessoa) REFERENCES PESSOA(CPF)
);

CREATE TABLE CONTATO (
    CPF_pessoa VARCHAR(11) NOT NULL,
    Telefone VARCHAR(15) NOT NULL,
    CONSTRAINT PK_CONTATO PRIMARY KEY (CPF_pessoa, Telefone),
    CONSTRAINT FK_CONTATO_PESSOA FOREIGN KEY (CPF_pessoa) REFERENCES PESSOA(CPF)
);

