-- QUESTÃO D: 
-- Consulta 1: INNER JOIN completo ordenado por Nome
SELECT P.Nome, P.Sexo, E.Cidade, E.Estado, C.Telefone
FROM PESSOA P
INNER JOIN ENDERECO E ON P.CPF = E.CPF_pessoa
INNER JOIN CONTATO C ON P.CPF = C.CPF_pessoa
ORDER BY P.Nome ASC;

-- Consulta 2: 
SELECT P.Nome, P.Sexo, E.Estado
FROM PESSOA P
INNER JOIN ENDERECO E ON P.CPF = E.CPF_pessoa
WHERE P.Sexo = 'F' OR E.Estado = 'SP'
LIMIT 2;

-- Consulta 3: Junção externa à esquerda (LEFT JOIN)
SELECT P.Nome, C.Telefone
FROM PESSOA P
LEFT JOIN CONTATO C ON P.CPF = C.CPF_pessoa;
